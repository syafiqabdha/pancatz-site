---
import '../styles/global.css';
import { site } from '../data/site';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/pancatz-logo.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — Creative & IT Support | Johor Bahru</title>
    <meta name="description" content="Calm craft design, printing, IT retainers and AI workflows for Johor businesses. Transparent pricing, warm personal service." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body class="grain">
    <header class="sticky top-0 z-50">
      <div class="section flex items-center justify-between py-5 md:py-6">
        <a href="/" class="flex items-center gap-3">
          <span class="text-xl md:text-2xl font-semibold tracking-[-1.5px] text-[var(--text)]">{site.name}</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a href="/pricing" class="nav-link">Pricing</a>
          <a href="/portfolio" class="nav-link">Work</a>
          <a href="#services" class="nav-link">Services</a>
          <a href="#testimonials" class="nav-link">Stories</a>
        </nav>

        <div class="flex items-center gap-2 md:gap-3">
          <a href={waLink} target="_blank" class="btn-primary text-[13px] px-5 py-2">Chat on WhatsApp</a>
          <button id="mobile-menu" class="md:hidden p-2 text-2xl leading-none">☰</button>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="pt-16 pb-10 text-sm">
      <div class="section flex flex-col md:flex-row justify-between gap-10 text-xs tracking-[0.5px]">
        <div>
          <div class="font-semibold text-[var(--text)] mb-1">{site.name}</div>
          <div class="text-[var(--text-muted)]">Johor Bahru • Malaysia</div>
        </div>
        <div class="flex flex-wrap gap-x-7 gap-y-2 text-[var(--text-muted)]">
          <a href="/pricing" class="hover:text-[var(--text)]">Pricing</a>
          <a href="/portfolio" class="hover:text-[var(--text)]">Work</a>
          <a href="mailto:{site.email}" class="hover:text-[var(--text)]">Email</a>
          <a href={site.instagramUrl} target="_blank" class="hover:text-[var(--text)]">Instagram</a>
        </div>
        <div class="text-[var(--text-muted)]">© {new Date().getFullYear()}</div>
      </div>
    </footer>

    <!-- Mobile drawer -->
    <div id="mobile-drawer" class="hidden md:hidden fixed inset-0 bg-[var(--bg)] z-[90] pt-20">
      <div class="section flex flex-col gap-1 text-lg">
        <a href="/pricing" class="mobile-nav-link py-3 border-b border-[var(--border)]">Pricing</a>
        <a href="/portfolio" class="mobile-nav-link py-3 border-b border-[var(--border)]">Work</a>
        <a href="#services" class="mobile-nav-link py-3 border-b border-[var(--border)]">Services</a>
        <a href={waLink} target="_blank" class="mt-8 btn-primary justify-center">Chat on WhatsApp</a>
      </div>
    </div>

    <script>
      const mobileBtn = document.getElementById('mobile-menu');
      const drawer = document.getElementById('mobile-drawer');
      if (mobileBtn && drawer) {
        mobileBtn.addEventListener('click', () => {
          const isOpen = !drawer.classList.contains('hidden');
          if (isOpen) {
            drawer.classList.add('hidden');
            mobileBtn.textContent = '☰';
            document.body.style.overflow = '';
          } else {
            drawer.classList.remove('hidden');
            mobileBtn.textContent = '✕';
            document.body.style.overflow = 'hidden';
          }
        });
        drawer.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            drawer.classList.add('hidden');
            mobileBtn.textContent = '☰';
            document.body.style.overflow = '';
          });
        });
      }

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </body>
</html>