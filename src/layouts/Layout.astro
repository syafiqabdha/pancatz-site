---
import '../styles/global.css';
import { site, navItems } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = `${site.name} | ${site.tagline}`,
  description = site.description,
  path = '/',
} = Astro.props;

const url = new URL(path, Astro.site ?? 'https://pancatz.com').toString();
const socialImage = new URL('/og-image.svg', Astro.site ?? 'https://pancatz.com').toString();
const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@500;700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={url} />
  </head>
  <body class="bg-paper text-zinc-800 antialiased">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="sticky top-0 z-40 border-b border-zinc-200 bg-paper">
      <div class="section flex items-center justify-between gap-3 py-3">
        <a href="/" class="focus-ring flex shrink-0 items-center gap-2 rounded-md">
          <img src="/pancatz-logo.webp" alt="Pancatz" width="36" height="36" class="h-9 w-9 rounded-xl object-cover" />
          <span class="hidden text-lg font-bold tracking-tight text-zinc-900 sm:inline">{site.name}</span>
        </a>
        <nav aria-label="Main navigation" class="min-w-0 overflow-x-auto">
          <ul class="flex min-w-max items-center gap-1 sm:gap-3">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'focus-ring rounded-full px-3 py-2 text-sm font-medium whitespace-nowrap transition-colors',
                    path === item.href ? 'bg-zinc-900 text-white' : 'text-zinc-700 hover:bg-zinc-100 hover:text-zinc-900',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <section class="section py-8">
      <div class="grid gap-3 rounded-3xl border border-zinc-200 bg-white p-4 text-sm sm:grid-cols-3">
        <p><strong>Fast quote flow</strong><br />Clear scope before work starts.</p>
        <p><strong>Print + tech capable</strong><br />Creative and IT support in one place.</p>
        <p><strong>Practical handover</strong><br />Files, setup notes, and next steps included.</p>
      </div>
    </section>

    <footer class="mt-8 border-t border-zinc-200 bg-white">
      <div class="section grid gap-8 py-10 lg:grid-cols-3">
        <div>
          <h2 class="text-base font-semibold text-zinc-900">{site.name}</h2>
          <p class="mt-2 text-sm leading-6 text-zinc-600">Creative and technical delivery in one practical service desk.</p>
        </div>
        <div>
          <h2 class="text-base font-semibold text-zinc-900">Service Hubs</h2>
          <ul class="mt-2 space-y-1 text-sm text-zinc-600">
            <li><span class="font-medium text-zinc-800">Creative Hub:</span> Printing, Graphic Design</li>
            <li><span class="font-medium text-zinc-800">IT Services:</span> Support, Hardware, AI</li>
          </ul>
        </div>
        <div>
          <h2 class="text-base font-semibold text-zinc-900">Contact</h2>
          <ul class="mt-2 space-y-2 text-sm text-zinc-600">
            <li><a class="focus-ring rounded text-zinc-700 hover:text-zinc-900" href={`mailto:${site.email}`}>{site.email}</a></li>
            <li><a class="focus-ring rounded text-zinc-700 hover:text-zinc-900" href={waLink} target="_blank" rel="noreferrer">WhatsApp: {site.phoneDisplay}</a></li>
            <li><a class="focus-ring rounded text-zinc-700 hover:text-zinc-900" href={site.instagramUrl} target="_blank" rel="noreferrer">Instagram</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-zinc-200 py-4 text-center text-xs text-zinc-500">© {new Date().getFullYear()} {site.name}. All rights reserved.</div>
    </footer>

    <a href={waLink} class="wa-fab interactive-lift focus-ring" target="_blank" rel="noreferrer" aria-label="Chat with Pancatz on WhatsApp">
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M20.5 3.5A11.5 11.5 0 0 0 2.3 17.2L1 23l5.9-1.3A11.5 11.5 0 1 0 20.5 3.5Zm-8.9 17a9.4 9.4 0 0 1-4.8-1.3l-.3-.2-3.5.8.8-3.4-.2-.3a9.4 9.4 0 1 1 8 4.4Zm5.2-7.1c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.8.2-.2.3-.9 1-1 1.1-.2.2-.4.2-.7 0a7.7 7.7 0 0 1-2.3-1.4 8.8 8.8 0 0 1-1.6-2c-.2-.3 0-.5.2-.7l.5-.6c.2-.2.2-.4.3-.6.1-.2 0-.4 0-.6l-1-2.4c-.2-.5-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.2 1.2-1.2 2.9s1.2 3.4 1.3 3.6c.2.2 2.3 3.5 5.5 4.8.8.3 1.4.5 1.9.7.8.3 1.6.3 2.2.2.7-.1 1.9-.8 2.2-1.5.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3Z"/></svg>
      <span>WhatsApp Quote</span>
    </a>
  </body>
</html>
