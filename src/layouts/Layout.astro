---
import '../styles/global.css';
import { site } from '../data/site';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/pancatz-logo.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.name} — Creative & IT Support | Johor Bahru</title>
    <meta name="description" content="Calm craft design, printing, IT retainers and AI workflows for Johor businesses. Transparent pricing, warm personal service." />
    <meta property="og:image" content="/images/og-image.png" />
    <meta name="twitter:image" content="/images/og-image.png" />
  </head>
  <body>
    <header id="site-header" class="site-header">
      <div class="section flex items-center justify-between py-4 md:py-5">
        <a href="/" class="flex items-center gap-3 header-logo">
          <img src="/pancatz-logo.jpg" alt="Pancatz" class="h-9 w-9 md:h-10 md:w-10 rounded-full object-cover" />
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a href="/pricing" class="nav-link">Pricing</a>
          <a href="/portfolio" class="nav-link">Work</a>
          <a href="/#services" class="nav-link">Services</a>
        </nav>

        <div class="flex items-center gap-2 md:gap-3">
          <a href={waLink} target="_blank" class="btn-primary text-[13px] px-5 py-2">Chat on WhatsApp</a>
          <button id="mobile-menu" class="md:hidden p-2 text-2xl leading-none">&#9776;</button>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="pt-16 pb-10 text-sm border-t border-[var(--surface-border)] relative overflow-hidden">
      <!-- Living Clay Mesh Gradient Background -->
      <div class="absolute inset-0 z-0 pointer-events-none opacity-30">
        <div class="mesh-blob absolute w-[60vw] h-[60vw] max-w-[700px] max-h-[700px] bg-[#d4b39c] rounded-full left-[-15%] top-[-20%] filter blur-[90px] opacity-60"></div>
        <div class="mesh-blob absolute w-[50vw] h-[50vw] max-w-[600px] max-h-[600px] bg-[var(--primary)] rounded-full right-[-10%] top-[10%] filter blur-[100px] opacity-50"></div>
        <div class="mesh-blob absolute w-[55vw] h-[55vw] max-w-[650px] max-h-[650px] bg-[#e5e0d6] rounded-full left-[20%] bottom-[-30%] filter blur-[80px] opacity-70"></div>
      </div>
      <div class="section flex flex-col md:flex-row justify-between gap-10 text-xs tracking-[0.5px] relative z-10">
        <div>
          <div class="font-semibold text-[var(--ink)] mb-1">{site.name}</div>
          <div class="text-[var(--muted-ink)]">Johor Bahru • Malaysia</div>
        </div>
        <div class="flex flex-wrap gap-x-7 gap-y-2 text-[var(--muted-ink)]">
          <a href="/pricing" class="hover:text-[var(--ink)]">Pricing</a>
          <a href="/portfolio" class="hover:text-[var(--ink)]">Work</a>
          <a href="mailto:{site.email}" class="hover:text-[var(--ink)]">Email</a>
          <a href={site.instagramUrl} target="_blank" class="hover:text-[var(--ink)]">Instagram</a>
        </div>
        <div class="text-[var(--muted-ink)]">© {new Date().getFullYear()} Pancatz</div>
      </div>
    </footer>

    <!-- Mobile drawer -->
    <div id="mobile-drawer" class="hidden md:hidden fixed inset-0 bg-[var(--paper)] z-[90] pt-20">
      <div class="section flex flex-col gap-1 text-lg">
        <a href="/pricing" class="mobile-nav-link py-3 border-b border-[var(--surface-border)]">Pricing</a>
        <a href="/portfolio" class="mobile-nav-link py-3 border-b border-[var(--surface-border)]">Work</a>
        <a href="/#services" class="mobile-nav-link py-3 border-b border-[var(--surface-border)]">Services</a>
        <a href={waLink} target="_blank" class="mt-8 btn-primary justify-center">Chat on WhatsApp</a>
      </div>
    </div>

    <script>
      import { animate, onScroll, stagger } from 'animejs';

      const header = document.getElementById('site-header');
      const mobileBtn = document.getElementById('mobile-menu');
      const drawer = document.getElementById('mobile-drawer');

      // Mobile menu
      if (mobileBtn && drawer) {
        mobileBtn.addEventListener('click', () => {
          const isOpen = !drawer.classList.contains('hidden');
          if (isOpen) {
            drawer.classList.add('hidden');
            mobileBtn.textContent = '\u2630';
            document.body.style.overflow = '';
          } else {
            drawer.classList.remove('hidden');
            mobileBtn.textContent = '\u2715';
            document.body.style.overflow = 'hidden';
          }
        });
        drawer.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            drawer.classList.add('hidden');
            mobileBtn.textContent = '\u2630';
            document.body.style.overflow = '';
          });
        });
      }

      // Header show/hide on scroll direction
      let lastScrollY = window.scrollY;
      let ticking = false;

      function updateHeader() {
        const currentY = window.scrollY;
        if (currentY < lastScrollY) {
          // scrolling/pinching upward
          header.classList.add('visible');
        } else if (currentY > lastScrollY && currentY > 40) {
          // scrolling down, past hero top
          header.classList.remove('visible');
        }
        lastScrollY = currentY;
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateHeader);
          ticking = true;
        }
      }, { passive: true });

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Header starts visible; animate in the inner bar
      header.classList.add('visible');

      // Header entrance animation
      animate({
        targets: '.header-logo, header nav a, header .btn-primary',
        opacity: [0, 1],
        translateY: [-12, 0],
        duration: 700,
        easing: 'easeOutExpo',
        delay: stagger(40, { start: 100 })
      });

      // Global Mesh Gradient Animation
      function initMeshGradient() {
        const blobs = document.querySelectorAll('.mesh-blob');
        if (!blobs.length) return;

        blobs.forEach((blob, i) => {
          const xMove = i % 2 === 0 ? ['0%', '15%', '-5%', '0%'] : ['0%', '-10%', '10%', '0%'];
          const yMove = i % 3 === 0 ? ['0%', '10%', '-15%', '0%'] : ['0%', '-15%', '5%', '0%'];
          const scaleMove = i === 1 ? [1, 1.1, 0.95, 1] : [1, 0.95, 1.05, 1];

          animate({
            targets: blob,
            translateX: xMove,
            translateY: yMove,
            scale: scaleMove,
            duration: 12000 + (i * 2000), // Slow, fluid
            easing: 'easeInOutSine',
            loop: true
          });
        });
      }

      document.addEventListener('DOMContentLoaded', initMeshGradient);
    </script>
  </body>
</html>
