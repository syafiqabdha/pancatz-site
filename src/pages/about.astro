---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout path="/about" title={`About | ${site.name}`}>
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">About Pancatz</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">Pancatz is a practical service brand for people and small teams who want useful creative work and dependable tech support from one responsive contact point.</p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <article class="studio-card p-5">
        <h2 class="text-xl font-bold text-zinc-900">Our mission</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-600">Help businesses and individuals look professional, keep devices productive, and adopt simple digital workflows without unnecessary complexity.</p>
      </article>
      <article class="studio-card p-5">
        <h2 class="text-xl font-bold text-zinc-900">How we work</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-600">We start with your goal, suggest the simplest route, and keep communication clear via WhatsApp from quote to final handover.</p>
      </article>
      <article class="studio-card p-5 md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Two service lanes</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-zinc-200 bg-white p-4">
            <p class="kicker text-zinc-500">Creative Hub</p>
            <p class="mt-2 text-sm leading-6 text-zinc-600">Design systems, social assets, flyers, menus, labels, business cards, and other print-ready materials.</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-white p-4">
            <p class="kicker text-zinc-500">IT Services</p>
            <p class="mt-2 text-sm leading-6 text-zinc-600">Computer repair, maintenance, software setup, backup checks, AI tools, and lightweight workflow automation.</p>
          </div>
        </div>
      </article>
      <article class="studio-card p-5 md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Operating model</h2>
        <ol class="mt-4 grid gap-3 text-sm text-zinc-700 sm:grid-cols-5">
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">01</span><p class="mt-1 font-semibold">Goal</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">02</span><p class="mt-1 font-semibold">Scope</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">03</span><p class="mt-1 font-semibold">Quote</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">04</span><p class="mt-1 font-semibold">Produce</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">05</span><p class="mt-1 font-semibold">Handover</p></li>
        </ol>
      </article>
    </div>
  </section>
</Layout>
