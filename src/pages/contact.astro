---
import Layout from '../layouts/Layout.astro';
import { site, whatsappIntents } from '../data/site';
import { Button, Card } from '@astryxdesign/core';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`;
---

<Layout path="/contact" title={`Contact | ${site.name}`}>
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">Contact</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">Need a design quote, print estimate, computer repair, or AI workflow support? Message us with your requirement and preferred timeline.</p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <Card padding={6} variant="default" className="md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Free IT Health Check or Design Consultation</h2>
        <p class="mt-2 text-sm text-zinc-600">Fill in your details and we will follow up within 24 hours. No obligation, no commitment.</p>
        <form class="mt-6 grid gap-4 sm:grid-cols-3" method="POST" action={`mailto:${site.email}`} enctype="text/plain">
          <div>
            <label for="form-name" class="mb-1 block text-xs font-semibold uppercase tracking-wide text-zinc-500">Name</label>
            <input id="form-name" name="name" type="text" required placeholder="Your name" class="w-full rounded-lg border border-zinc-300 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]" />
          </div>
          <div>
            <label for="form-email" class="mb-1 block text-xs font-semibold uppercase tracking-wide text-zinc-500">Email</label>
            <input id="form-email" name="email" type="email" required placeholder="you@example.com" class="w-full rounded-lg border border-zinc-300 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]" />
          </div>
          <div>
            <label for="form-phone" class="mb-1 block text-xs font-semibold uppercase tracking-wide text-zinc-500">Phone / WhatsApp</label>
            <input id="form-phone" name="phone" type="tel" required placeholder="+60 1X-XXX XXXX" class="w-full rounded-lg border border-zinc-300 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]" />
          </div>
          <div class="sm:col-span-3">
            <label for="form-message" class="mb-1 block text-xs font-semibold uppercase tracking-wide text-zinc-500">How can we help?</label>
            <textarea id="form-message" name="message" rows={3} placeholder="Share a brief description of what you need..." class="w-full rounded-lg border border-zinc-300 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]"></textarea>
          </div>
          <div class="sm:col-span-3">
            <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-[var(--primary)] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--primary-ink)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2">Send Enquiry</button>
          </div>
        </form>
      </Card>

      <Card padding={5}>
        <h2 class="text-xl font-bold text-zinc-900">Fastest response: WhatsApp</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-600">Include your service lane, quantity or device details, deadline, and any reference file for a faster quotation.</p>
        <Button href={waLink} label="Open WhatsApp Chat" variant="primary" className="mt-5" target="_blank" rel="noreferrer" />
      </Card>

      <Card padding={5}>
        <h2 class="text-xl font-bold text-zinc-900">Other channels</h2>
        <ul class="mt-3 space-y-2 text-sm text-zinc-700">
          <li>Email: <a class="focus-ring rounded text-[var(--link)] hover:underline" href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>Phone: {site.phoneDisplay}</li>
          <li>Instagram: <a class="focus-ring rounded text-[var(--link)] hover:underline" href={site.instagramUrl} target="_blank" rel="noreferrer">@pancatz.design</a></li>
          <li>Service model: {site.area}</li>
        </ul>
      </Card>

      <Card padding={5} className="md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Quote prep checklist</h2>
        <p class="mt-2 text-sm text-zinc-600">Send these details first so we can reply with a clear and accurate estimate.</p>
        <ul class="mt-4 grid gap-2 text-sm text-zinc-700 sm:grid-cols-2">
          <li>• Service lane: Creative Hub or IT Services</li>
          <li>• Item, quantity, device, or workflow scope</li>
          <li>• Target deadline</li>
          <li>• Preferred output format or support outcome</li>
          <li>• Any reference image, file, or error screenshot</li>
          <li>• Budget range (optional)</li>
        </ul>
      </Card>
    </div>
  </section>
</Layout>
