---
import Layout from '../layouts/Layout.astro';
import { site, whatsappIntents } from '../data/site';
import { Button, Card, Badge } from '@astryxdesign/core';

const waLink = (msg: string) =>
  `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(msg)}`;
const waGeneral = waLink(whatsappIntents.general);
const waCreative = waLink(whatsappIntents.creativeHub);
const waPrint = waLink(whatsappIntents.printing);
const waRepair = waLink(whatsappIntents.repair);
const waItAi = waLink(whatsappIntents.itAi);
---

<Layout path="/pricing" title={`Pricing & Packages | ${site.name} | Johor Bahru, Malaysia`}>
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">Pricing & Packages</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">Transparent pricing for design, print, IT services, and retainer packages. All prices in RM (Malaysian Ringgit).</p>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">Creative Hub — Design</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {[
        { item: 'Logo Design', price: 'RM150', desc: 'Original logo with revisions and file formats.' },
        { item: 'Business Cards', price: 'RM80', desc: 'Design layout for double-sided cards.' },
        { item: 'Flyers', price: 'RM120', desc: 'A5/A4 flyer design with your branding.' },
        { item: 'Social Media Kit', price: 'RM200', desc: 'Set of 5 social media posts or stories.' },
        { item: 'Menu', price: 'RM180', desc: 'Menu design ready for print or digital.' },
        { item: 'Banner', price: 'RM150', desc: 'Banner design for web or print.' },
        { item: 'Full Brand Package', price: 'RM800', desc: 'Logo, cards, flyer, social kit, and guidelines.' },
      ].map((p) => (
        <Card padding={5} variant="default">
          <h3 class="text-lg font-bold text-zinc-900">{p.item}</h3>
          <p class="mt-1 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waCreative} label="Quote" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">Creative Hub — Print</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {[
        { item: 'Business Cards', price: 'RM30/100pcs', desc: 'Premium card stock, double-sided.' },
        { item: 'Flyers A5', price: 'RM35/100pcs', desc: 'Full colour, one-sided A5 flyers.' },
        { item: 'Flyers A4', price: 'RM50/100pcs', desc: 'Full colour, one-sided A4 flyers.' },
        { item: 'Banners', price: 'RM8/sqft', desc: 'Indoor/outdoor banner printing.' },
        { item: 'Stickers', price: 'RM25/100pcs', desc: 'Custom cut sticker printing.' },
        { item: 'Booklets', price: 'RM2.50/pc', desc: 'Saddle-stitched booklet printing.' },
        { item: 'Posters A2/A1', price: 'RM5–12/pc', desc: 'Large format poster printing.' },
      ].map((p) => (
        <Card padding={5} variant="default">
          <h3 class="text-lg font-bold text-zinc-900">{p.item}</h3>
          <p class="mt-1 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waPrint} label="Quote" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">IT Services</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {[
        { item: 'PC Diagnosis', price: 'RM30', desc: 'Full diagnostic check on your device.' },
        { item: 'Windows Reinstall', price: 'RM80', desc: 'Clean OS reinstall with driver setup.' },
        { item: 'Virus Removal', price: 'RM60', desc: 'Malware cleanup and protection advice.' },
        { item: 'Hardware Upgrade', price: 'RM50 labour', desc: 'Labour for RAM, SSD, or part upgrade.' },
        { item: 'Data Recovery', price: 'RM100', desc: 'Attempt data retrieval from failed drives.' },
        { item: 'Network Setup', price: 'RM150', desc: 'Router, WiFi, and LAN configuration.' },
        { item: 'Printer Setup', price: 'RM50', desc: 'Driver install and network printer setup.' },
      ].map((p) => (
        <Card padding={5} variant="default">
          <h3 class="text-lg font-bold text-zinc-900">{p.item}</h3>
          <p class="mt-1 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waRepair} label="Book" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">IT Retainer Packages</h2>
    <div class="grid gap-4 md:grid-cols-3">
      {[
        { name: 'Starter', price: 'RM199/mo', devices: '3 devices', desc: 'Basic support for home or small office.' },
        { name: 'Business', price: 'RM499/mo', devices: '8 devices', desc: 'Ongoing IT maintenance for growing teams.' },
        { name: 'Pro', price: 'RM899/mo', devices: '15 devices', desc: 'Full IT support with priority response.' },
      ].map((p) => (
        <Card padding={5} variant="default" className="flex flex-col">
          <Badge label={p.name} variant="neutral" />
          <p class="mt-3 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="text-sm text-zinc-500">Up to {p.devices}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waItAi} label="Enquire" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">Creative Retainer Packages</h2>
    <div class="grid gap-4 md:grid-cols-3">
      {[
        { name: 'Lite', price: 'RM299/mo', desc: 'Up to 5 design requests per month.' },
        { name: 'Standard', price: 'RM599/mo', desc: 'Up to 12 design requests per month.' },
        { name: 'Pro', price: 'RM1,200/mo', desc: 'Unlimited design requests with priority.' },
      ].map((p) => (
        <Card padding={5} variant="default" className="flex flex-col">
          <Badge label={p.name} variant="neutral" />
          <p class="mt-3 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waCreative} label="Enquire" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">Combined Retainer Packages</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {[
        { name: 'Small Business', price: 'RM799/mo', desc: 'IT support up to 5 devices + 3 design requests per month.' },
        { name: 'Growing Business', price: 'RM1,500/mo', desc: 'IT support up to 12 devices + 8 design requests per month.' },
      ].map((p) => (
        <Card padding={6} variant="default" className="flex flex-col">
          <Badge label={p.name} variant="primary" />
          <p class="mt-3 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waGeneral} label="Enquire Now" variant="primary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-8">
    <h2 class="page-title mb-6 font-bold text-zinc-900">AI Services</h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {[
        { item: 'AI Consultation', price: 'RM150', desc: 'One-hour consultation on AI opportunities for your business.' },
        { item: 'Chatbot Setup', price: 'RM300', desc: 'Simple AI chatbot for your website or WhatsApp.' },
        { item: 'n8n Workflow', price: 'RM500', desc: 'Custom automation workflow built in n8n.' },
        { item: 'ComfyUI Setup', price: 'RM300', desc: 'Install and configure ComfyUI for image generation.' },
        { item: 'Custom AI Solution', price: 'RM800+', desc: 'Tailored AI solution scoped to your needs.' },
      ].map((p) => (
        <Card padding={5} variant="default">
          <h3 class="text-lg font-bold text-zinc-900">{p.item}</h3>
          <p class="mt-1 text-2xl font-bold text-[var(--primary)]">{p.price}</p>
          <p class="mt-2 text-sm text-zinc-600">{p.desc}</p>
          <Button href={waItAi} label="Enquire" variant="secondary" className="mt-4" target="_blank" rel="noreferrer" />
        </Card>
      ))}
    </div>
  </section>

  <section class="section pb-16">
    <Card padding={6} variant="default" className="text-center">
      <h2 class="text-2xl font-bold text-zinc-900">Need a custom package?</h2>
      <p class="mt-2 text-zinc-600">Tell us your requirements and we will prepare a tailored quote for your business.</p>
      <Button href={waGeneral} label="Chat on WhatsApp" variant="primary" className="mt-6" target="_blank" rel="noreferrer" />
    </Card>
  </section>
</Layout>
