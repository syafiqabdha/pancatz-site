---
import Layout from '../layouts/Layout.astro';
import { site, whatsappIntents } from '../data/site';

const wa = (msg) => `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(msg)}`;
---

<Layout title="Pricing — Pancatz">
  <div class="section max-w-5xl mx-auto py-28">
    <div class="mb-12 section-reveal">
      <div class="uppercase tracking-[3px] text-xs mb-3 text-[var(--primary)]">TRANSPARENT</div>
      <h1 class="page-title">Simple pricing.<br />Real results.</h1>
      <p class="mt-4 max-w-md text-[var(--muted-ink)]">Choose a starting point. We’ll adjust on WhatsApp.</p>
    </div>

    <div class="mb-10 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-3 text-[var(--primary)]">START WITH ONE</div>
      <div class="flex flex-wrap gap-3" id="pricing-steps">
        <button data-step="creative" class="step-btn unified-card interactive-lift px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium active">Creative</button>
        <button data-step="print" class="step-btn unified-card interactive-lift px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">Print</button>
        <button data-step="it" class="step-btn unified-card interactive-lift px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">IT Support</button>
        <button data-step="ai" class="step-btn unified-card interactive-lift px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">AI & Automation</button>
        <button data-step="retainer" class="step-btn unified-card interactive-lift px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">Retainers</button>
      </div>
    </div>

    <div id="pricing-content" class="space-y-6 card-grid" data-wa="60137572507">
      <!-- injected -->
    </div>

    <div class="mt-14 text-xs text-[var(--muted-ink)] max-w-md section-reveal">
      All prices in MYR. Custom work quoted after a quick chat. Monthly retainers include priority support.
    </div>
  </div>
</Layout>

<script>
  import { animate, onScroll, stagger } from 'animejs';

  const content = document.getElementById('pricing-content');
  const steps = document.querySelectorAll('.step-btn');

  const pricingData = {
    creative: {
      title: "Creative",
      items: [
        { name: "Logo + basic brand", price: "RM 890" },
        { name: "Full visual identity", price: "RM 1,890" },
        { name: "Social + print pack", price: "from RM 1,450" }
      ],
      note: "Includes 2 rounds of revisions. Source files delivered."
    },
    print: {
      title: "Print Production",
      items: [
        { name: "Business cards (500)", price: "RM 380" },
        { name: "A3 posters (100)", price: "RM 620" },
        { name: "Full signage set", price: "quoted" }
      ],
      note: "High-quality local printing. Fast turnaround."
    },
    it: {
      title: "IT Support",
      items: [
        { name: "One-time repair", price: "RM 180–280" },
        { name: "Monthly basic", price: "RM 380/mo" },
        { name: "Monthly full", price: "RM 680/mo" }
      ],
      note: "On-site in JB area. Remote support included."
    },
    ai: {
      title: "AI & Automation",
      items: [
        { name: "Simple chatbot", price: "RM 1,250" },
        { name: "Workflow setup", price: "RM 980" },
        { name: "Custom image gen flow", price: "from RM 1,650" }
      ],
      note: "Built with tools you already use."
    },
    retainer: {
      title: "Monthly Retainers",
      items: [
        { name: "Starter (8h)", price: "RM 1,250/mo" },
        { name: "Growth (20h)", price: "RM 2,650/mo" },
        { name: "Full partnership", price: "RM 4,200/mo" }
      ],
      note: "Best value. Roll over unused hours. Priority response."
    }
  };

  const waNum = content.dataset.wa;
  const wa = (msg) => `https://wa.me/${waNum}?text=${encodeURIComponent(msg)}`;

  function render(step) {
    const data = pricingData[step];
    const card = document.createElement('div');
    card.className = 'card p-9 unified-card';
    card.innerHTML = `
      <div class="flex items-baseline justify-between mb-6">
        <h3 class="text-3xl font-semibold tracking-tight">${data.title}</h3>
        <a href="${wa('Hi Pancatz, I\'m interested in ' + data.title)}"
           class="text-sm underline hover:no-underline">Chat on WhatsApp →</a>
      </div>
      <div class="space-y-4 mb-8">
        ${data.items.map(i => `
          <div class="flex justify-between items-center border-b border-[var(--surface-border)] pb-4">
            <div>${i.name}</div>
            <div class="font-mono text-sm text-[var(--primary)]">${i.price}</div>
          </div>
        `).join('')}
      </div>
      <p class="text-sm text-[var(--muted-ink)]">${data.note}</p>
    `;
    content.innerHTML = '';
    content.appendChild(card);

    animate.set(card, { opacity: 0, translateY: 20 });
    animate({ targets: card, opacity: [0, 1], translateY: [20, 0], duration: 500, easing: 'easeOutExpo' });
  }

  if (content && steps.length) {
    steps.forEach(btn => {
      btn.addEventListener('click', () => {
        steps.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        render(btn.dataset.step);
      });
    });

    steps[0].classList.add('active');
    render('creative');
  }

  document.addEventListener('DOMContentLoaded', () => {
    animate.set('.section-reveal', { opacity: 0, translateY: 24 });
    document.querySelectorAll('.section-reveal').forEach(el => {
      onScroll({
        target: el,
        enter: 'top 85%',
        sync: false,
      }).add({
        targets: el,
        opacity: [0, 1],
        translateY: [24, 0],
        duration: 800,
        easing: 'easeOutExpo'
      });
    });

    document.querySelectorAll('.unified-card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        animate({ targets: card, translateY: -4, duration: 200, easing: 'easeOutCubic' });
      });
      card.addEventListener('mouseleave', () => {
        animate({ targets: card, translateY: 0, duration: 200, easing: 'easeOutCubic' });
      });
    });
  });
</script>
