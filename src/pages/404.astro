---
import Layout from '../layouts/Layout.astro';
---

<Layout path="/404" title="404 | Page not found">
  <section class="section py-16 sm:py-24">
    <div class="studio-card mx-auto max-w-2xl p-8 text-center sm:p-12">
      <p class="kicker text-zinc-500">404 / NOT FOUND</p>
      <h1 class="page-title mt-3 font-bold text-zinc-900">Page not found</h1>
      <p class="mt-4 text-base leading-7 text-zinc-600">The page you are looking for does not exist or may have been moved.</p>
      <a href="/" class="btn-primary interactive-lift focus-ring mt-8 inline-flex">Back to home</a>
    </div>
  </section>
</Layout>
