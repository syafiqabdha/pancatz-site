---
import Layout from '../layouts/Layout.astro';
---

<Layout path="/404" title="404 | Page not found">
  <section class="section py-16 sm:py-24">
    <div class="studio-card mx-auto max-w-2xl p-8 text-center sm:p-12">
      <p class="kicker text-zinc-500">404 / NOT FOUND</p>
      <h1 class="page-title mt-3 font-bold text-zinc-900">Page not found</h1>
      <p class="mt-4 text-base leading-7 text-zinc-600">The page you are looking for does not exist or may have moved during the Pancatz service refresh.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary interactive-lift focus-ring inline-flex">Back to home</a>
        <a href="/services" class="btn-secondary interactive-lift focus-ring inline-flex">View services</a>
        <a href="/contact" class="btn-secondary interactive-lift focus-ring inline-flex">Contact Pancatz</a>
      </div>
    </div>
  </section>
</Layout>
