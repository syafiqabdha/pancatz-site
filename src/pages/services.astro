---
import Layout from '../layouts/Layout.astro';
import { site, services } from '../data/site';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Layout path="/services" title={`Services | ${site.name}`}>
  <section class="section py-14 sm:py-20">
    <h1 class="text-4xl font-extrabold tracking-tight text-zinc-900 sm:text-5xl">Services</h1>
    <p class="mt-4 max-w-3xl text-base leading-7 text-zinc-600">Pancatz combines creative production and technical problem-solving so you can manage branding, marketing, and IT needs in one place.</p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {services.map((service) => (
        <article id={service.slug} class="card">
          <h2 class="text-xl font-bold text-zinc-900">{service.title}</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-600">{service.description}</p>
          <ul class="mt-4 space-y-2 text-sm text-zinc-700">
            {service.bullets.map((bullet) => (
              <li>• {bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section pb-16">
    <div class="rounded-3xl border border-zinc-200 bg-white p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-zinc-900">Request a custom package</h2>
      <p class="mt-2 text-zinc-600">Tell us your budget, target date, and goals. We can combine design, print, photography, and support into one smooth delivery plan.</p>
      <a href={waLink} class="btn-primary mt-6" target="_blank" rel="noreferrer">Chat on WhatsApp</a>
    </div>
  </section>
</Layout>
