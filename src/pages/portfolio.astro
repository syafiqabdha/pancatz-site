---
import Layout from '../layouts/Layout.astro';
import { portfolioItems } from '../data/site';
---

<Layout path="/portfolio" title="Portfolio | Pancatz">
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">Portfolio & Gallery</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">A snapshot of the type of work we do for local brands, families, schools, and SMEs. Current visuals are representative samples while case-study assets are being expanded.</p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {portfolioItems.map((item) => (
        <article class="studio-card interactive-lift overflow-hidden">
          <div class="overflow-hidden">
            <img src={item.image} alt={item.title} class="h-56 w-full object-cover" loading="lazy" />
          </div>
          <div class="p-4">
            <div class="flex items-center justify-between gap-2">
              <p class="kicker text-zinc-500">{item.category}</p>
              <span class="rounded-full border border-zinc-300 px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.1em] text-zinc-600">{item.status}</span>
            </div>
            <h2 class="mt-2 text-lg font-bold text-zinc-900">{item.title}</h2>
            <p class="mt-2 text-sm text-zinc-600">{item.summary}</p>
            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-500">Deliverables</p>
            <ul class="mt-1 space-y-1 text-sm text-zinc-700">
              {item.deliverables.map((entry) => (
                <li>• {entry}</li>
              ))}
            </ul>
            <p class="mt-3 text-sm text-zinc-600"><span class="font-semibold text-zinc-800">Turnaround:</span> {item.turnaround}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>
