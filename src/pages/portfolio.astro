---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work — Pancatz">
  <div class="section max-w-5xl mx-auto py-16">
    <div class="mb-10">
      <div class="uppercase tracking-[3px] text-xs mb-2 text-[var(--primary)]">SELECT WORK</div>
      <h1 class="page-title">Work that holds up.</h1>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="portfolio-card studio-card p-8">
        <div class="h-56 mb-6 bg-[var(--paper)] rounded-2xl flex items-center justify-center text-[var(--muted-ink)] text-sm">Creative systems for local brands</div>
        <div class="font-semibold tracking-tight text-2xl">Local restaurant rebrand + full signage</div>
        <div class="mt-2 text-sm text-[var(--muted-ink)]">Creative • Print</div>
      </div>

      <div class="portfolio-card studio-card p-8">
        <div class="h-56 mb-6 bg-[var(--paper)] rounded-2xl flex items-center justify-center text-[var(--muted-ink)] text-sm">Reliable tech foundations</div>
        <div class="font-semibold tracking-tight text-2xl">Clinic network + AI appointment bot</div>
        <div class="mt-2 text-sm text-[var(--muted-ink)]">IT • Automation</div>
      </div>
    </div>

    <p class="mt-10 text-sm text-[var(--muted-ink)] max-w-xs">More case studies available on request. We focus on work that actually improves how small businesses operate and look.</p>
  </div>
</Layout>