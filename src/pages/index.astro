---
import Layout from '../layouts/Layout.astro';
import { site, whatsappIntents } from '../data/site';

const waGeneral = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`;
const waCreative = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.creativeHub)}`;
const waIT = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.repair)}`;
const waAI = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.itAi)}`;

const startHereItems = [
  { tag: "CREATIVE", title: "Design or Print", desc: "Logo • Cards • Flyers • Brand", link: waCreative },
  { tag: "IT SUPPORT", title: "Fix or Maintain", desc: "Repairs • Retainers • Setup", link: waIT },
  { tag: "AUTOMATION", title: "AI & Workflows", desc: "Chatbots • n8n • Image gen", link: waAI },
  { tag: "PLANS", title: "Monthly Retainers", desc: "Predictable cost, always on", link: "/pricing" }
];
---

<Layout>
  <!-- Hero -->
  <section class="section raw-grid pt-28 sm:pt-36 pb-24 sm:pb-32 relative overflow-hidden">
    <div class="max-w-5xl relative z-10">
      <h1 class="hero-title" id="hero-headline">
      </h1>
      <span id="hero-cursor" class="hero-cursor"></span>

      <p class="mt-7 max-w-md text-[1.05rem] text-[var(--muted-ink)] hero-reveal">
        One team for creative work and tech support. Premium design, print, and intelligent systems that keep your business moving.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row flex-wrap gap-4 hero-reveal">
        <a href="#what-you-need" class="btn-primary btn-magnetic">What do you need?</a>
        <a href="/pricing" class="btn-secondary btn-magnetic bg-[var(--surface-solid)]">See pricing</a>
      </div>
    </div>

    <!-- Living Clay Mesh Gradient Background -->
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-30">
      <div class="mesh-blob absolute w-[60vw] h-[60vw] max-w-[700px] max-h-[700px] bg-[#d4b39c] rounded-full left-[-15%] top-[-20%] filter blur-[90px] opacity-60"></div>
      <div class="mesh-blob absolute w-[50vw] h-[50vw] max-w-[600px] max-h-[600px] bg-[var(--primary)] rounded-full right-[-10%] top-[10%] filter blur-[100px] opacity-50"></div>
      <div class="mesh-blob absolute w-[55vw] h-[55vw] max-w-[650px] max-h-[650px] bg-[#e5e0d6] rounded-full left-[20%] bottom-[-30%] filter blur-[80px] opacity-70"></div>
    </div>
  </section>

  <!-- Conversational starter -->
  <section id="what-you-need" class="section py-10 border-t border-[var(--surface-border)] overflow-hidden">
    <div class="mb-6 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">START HERE</div>
      <h2 class="page-title">What do you need right now?</h2>
    </div>

    <div class="marquee-wrapper relative w-full overflow-hidden py-4 -mx-5 px-5 md:-mx-12 md:px-12 mt-4 section-reveal">
      <!-- Gradient masks for smooth edges -->
      <div class="absolute left-0 top-0 bottom-0 w-12 md:w-24 bg-gradient-to-r from-[var(--paper)] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-12 md:w-24 bg-gradient-to-l from-[var(--paper)] to-transparent z-10 pointer-events-none"></div>

      <div class="flex gap-4 w-max hover-pause">
        <div class="flex gap-4 w-max animate-marquee">
          {startHereItems.map((item) => (
            <div class="marquee-card group relative flex flex-col justify-between p-7 bg-[var(--surface-solid)] border border-[var(--surface-border)] rounded-2xl shrink-0 overflow-hidden cursor-pointer" style="width: 280px; height: 260px; transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);">
              <div class="relative z-10">
                 <div class="text-[var(--primary)] text-xs font-semibold tracking-[2px] mb-3">{item.tag}</div>
                 <h3 class="font-semibold text-2xl tracking-[-0.02em] text-[var(--ink)] whitespace-normal leading-tight">{item.title}</h3>
              </div>
              
              <div class="mt-8 flex flex-col justify-end relative h-full">
                 <p class="text-[15px] text-[var(--muted-ink)] whitespace-normal transition-all duration-300 group-hover:opacity-0 group-hover:-translate-y-2 absolute bottom-0 left-0 right-0">{item.desc}</p>
                 <div class="opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-75 absolute bottom-0 left-0 right-0 z-20 pointer-events-none group-hover:pointer-events-auto">
                   <a href={item.link} class="btn-primary w-full text-center py-3.5 text-[15px] inline-block shadow-lg">Start Project</a>
                 </div>
              </div>
            </div>
          ))}
        </div>
        <div class="flex gap-4 w-max animate-marquee" aria-hidden="true">
          {startHereItems.map((item) => (
            <div class="marquee-card group relative flex flex-col justify-between p-7 bg-[var(--surface-solid)] border border-[var(--surface-border)] rounded-2xl shrink-0 overflow-hidden cursor-pointer" style="width: 280px; height: 260px; transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);">
              <div class="relative z-10">
                 <div class="text-[var(--primary)] text-xs font-semibold tracking-[2px] mb-3">{item.tag}</div>
                 <h3 class="font-semibold text-2xl tracking-[-0.02em] text-[var(--ink)] whitespace-normal leading-tight">{item.title}</h3>
              </div>
              
              <div class="mt-8 flex flex-col justify-end relative h-full">
                 <p class="text-[15px] text-[var(--muted-ink)] whitespace-normal transition-all duration-300 group-hover:opacity-0 group-hover:-translate-y-2 absolute bottom-0 left-0 right-0">{item.desc}</p>
                 <div class="opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-75 absolute bottom-0 left-0 right-0 z-20 pointer-events-none group-hover:pointer-events-auto">
                   <a href={item.link} class="btn-primary w-full text-center py-3.5 text-[15px] inline-block shadow-lg">Start Project</a>
                 </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Hubs -->
  <section id="services" class="section border-t border-[var(--surface-border)] py-16">
    <div class="mb-8 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">WHAT WE DO</div>
      <h2 class="page-title">Two lanes.<br />One team.</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5 card-grid">
      <div class="card p-9 unified-card">
        <div class="uppercase text-xs tracking-[2px] text-[var(--primary)] mb-4">CREATIVE HUB</div>
        <h3 class="text-3xl font-semibold tracking-[-0.03em] mb-5">Design that prints.<br />Brands that last.</h3>

        <div class="text-[var(--muted-ink)] space-y-1.5 mb-10 text-[15px]">
          <div>Logo & brand systems</div>
          <div>Business cards, flyers, packaging</div>
          <div>Social kits & menus</div>
          <div>Banners, signage, print production</div>
        </div>

        <a href={waCreative} class="btn-secondary">Talk on WhatsApp</a>
      </div>

      <div class="card p-9 unified-card">
        <div class="uppercase text-xs tracking-[2px] text-[var(--primary)] mb-4">IT SERVICES</div>
        <h3 class="text-3xl font-semibold tracking-[-0.03em] mb-5">Systems that work.<br />Support that shows up.</h3>

        <div class="text-[var(--muted-ink)] space-y-1.5 mb-10 text-[15px]">
          <div>PC, laptop & hardware repair</div>
          <div>Network, WiFi & infrastructure</div>
          <div>Monthly Tech Care retainers</div>
          <div>AI automation & workflows</div>
        </div>

        <a href={waIT} class="btn-secondary">Talk on WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="portfolio" class="section border-t border-[var(--surface-border)] py-16">
    <div class="mb-8 flex items-end justify-between section-reveal">
      <div>
        <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">SELECT WORK</div>
        <h2 class="page-title">Work that holds up.</h2>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-5 card-grid">
      <div class="card p-0 overflow-hidden unified-card portfolio-card group">
        <img src="/images/portfolio-cafe.png" alt="Café brand" class="w-full h-56 object-cover" />
        <div class="p-9">
          <h3 class="text-2xl font-semibold tracking-tight">Brand refresh for a local café</h3>
          <p class="text-sm text-[var(--muted-ink)] mt-2">Logo, menu, signage, and social templates.</p>
        </div>
      </div>
      <div class="card p-0 overflow-hidden unified-card portfolio-card group">
        <img src="/images/portfolio-retail.png" alt="Retail IT setup" class="w-full h-56 object-cover" />
        <div class="p-9">
          <h3 class="text-2xl font-semibold tracking-tight">IT setup for a retail chain</h3>
          <p class="text-sm text-[var(--muted-ink)] mt-2">Network, POS terminals, and monthly support.</p>
        </div>
      </div>
      <div class="card p-0 overflow-hidden unified-card portfolio-card group">
        <img src="/images/portfolio-clinic.png" alt="Clinic print" class="w-full h-56 object-cover" />
        <div class="p-9">
          <h3 class="text-2xl font-semibold tracking-tight">Print collateral for a clinic</h3>
          <p class="text-sm text-[var(--muted-ink)] mt-2">Brochures, appointment cards, and wall displays.</p>
        </div>
      </div>
      <div class="card p-0 overflow-hidden unified-card portfolio-card group">
        <img src="/images/portfolio-property.png" alt="Property AI workflow" class="w-full h-56 object-cover" />
        <div class="p-9">
          <h3 class="text-2xl font-semibold tracking-tight">AI workflow for a property team</h3>
          <p class="text-sm text-[var(--muted-ink)] mt-2">Chatbot + image generation + lead routing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section border-t border-[var(--surface-border)] py-16">
    <div class="mb-8 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">TRANSPARENT</div>
      <h2 class="page-title">Simple pricing.<br />Real results.</h2>
    </div>

    <div class="mb-10 section-reveal">
      <div class="flex flex-wrap gap-3" id="pricing-steps">
        <button data-step="creative" class="step-btn unified-card hover:bg-[var(--surface)] transition-colors px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">Creative</button>
        <button data-step="print" class="step-btn unified-card hover:bg-[var(--surface)] transition-colors px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">Print</button>
        <button data-step="it" class="step-btn unified-card hover:bg-[var(--surface)] transition-colors px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">IT Support</button>
        <button data-step="ai" class="step-btn unified-card hover:bg-[var(--surface)] transition-colors px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">AI & Automation</button>
        <button data-step="retainer" class="step-btn unified-card hover:bg-[var(--surface)] transition-colors px-6 py-2.5 rounded-full border border-[var(--surface-border)] text-sm font-medium">Retainers</button>
      </div>
    </div>

    <div id="pricing-content" class="space-y-6 card-grid" data-wa="60137572507">
      <!-- injected -->
    </div>

    <div class="mt-10 text-xs text-[var(--muted-ink)] max-w-md section-reveal">
      All prices in MYR. Custom work quoted after a quick chat. Monthly retainers include priority support.
    </div>
  </section>

  <!-- Closer -->
  <section class="section py-16 sm:py-24 border-t border-[var(--surface-border)] text-center section-reveal">
    <div class="max-w-4xl mx-auto">
      <p class="text-[var(--ink)] cta-text font-semibold tracking-tight">Ready when you are.</p>
      <a href={waGeneral} class="btn-primary inline-block mt-6 sm:mt-8">Start a conversation</a>
    </div>
  </section>
</Layout>

<script>
  import { animate, onScroll, stagger, createTimeline } from 'animejs';

  // Reusable motion tokens
  const ease = 'easeOutExpo';
  const baseDuration = 800;

  // Typing effect on hero headline
  function initTypingEffect() {
    const headline = document.getElementById('hero-headline');
    const cursor = document.getElementById('hero-cursor');
    if (headline && cursor) {
      const sequences = [
        { text: 'Design and system', pause: 1000 },
        { text: 'Design that print', pause: 1000 },
        { text: 'System that run', pause: 1000 }
      ];

      const typeSpeed = 80;
      const deleteSpeed = 45;
      const holdDuration = 1000;
      const gapDuration = 300;

      function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }

      async function typeText(text) {
        for (let i = 0; i <= text.length; i++) {
          headline.textContent = text.slice(0, i);
          await sleep(typeSpeed);
        }
      }

      async function deleteText() {
        const text = headline.textContent;
        for (let i = text.length; i >= 0; i--) {
          headline.textContent = text.slice(0, i);
          await sleep(deleteSpeed);
        }
      }

      async function playSequence() {
        for (const seq of sequences) {
          await typeText(seq.text);
          await sleep(holdDuration);
          await deleteText();
          await sleep(gapDuration);
        }
        await typeText("Let's transform today");
      }

      playSequence();
    }
  }

  // Hero reveal sequence for sub + buttons
  function initHeroReveal() {
    animate({
      targets: '.hero-reveal',
      opacity: [0, 1],
      translateY: [24, 0],
      duration: baseDuration,
      easing: ease,
      delay: stagger(120, { start: 200 })
    });
  }

  // Section reveals on scroll
  function initScrollReveals() {
    animate.set('.section-reveal', { opacity: 0, translateY: 24 });
    document.querySelectorAll('.section-reveal').forEach(el => {
      onScroll({
        target: el,
        enter: 'top 85%',
        leave: 'bottom 10%',
        sync: false,
        debug: false,
      }).add({
        targets: el,
        opacity: [0, 1],
        translateY: [24, 0],
        duration: baseDuration,
        easing: ease
      });
    });

    // Card stagger reveals per section
    document.querySelectorAll('.card-grid').forEach(grid => {
      const cards = grid.querySelectorAll('.unified-card');
      animate.set(cards, { opacity: 0, translateY: 30, scale: 0.98 });
      onScroll({
        target: grid,
        enter: 'top 85%',
        leave: 'bottom 10%',
        sync: false,
      }).add({
        targets: cards,
        opacity: [0, 1],
        translateY: [30, 0],
        scale: [0.98, 1],
        duration: 900,
        easing: ease,
        delay: stagger(80)
      });
    });
  }

  // Unified card hover effect (lift + spotlight)
  function initCards() {
    document.querySelectorAll('.unified-card').forEach(card => {
      const spotlight = document.createElement('span');
      spotlight.className = 'card-spotlight';
      card.appendChild(spotlight);

      card.addEventListener('mouseenter', () => {
        animate({
          targets: card,
          translateY: -6,
          boxShadow: ['0 0 0 rgba(15,14,12,0)', '8px 12px 0 rgba(15,14,12,0.12)'],
          duration: 250,
          easing: 'easeOutCubic'
        });
        animate({ targets: spotlight, opacity: [0, 1], duration: 250, easing: 'easeOutCubic' });
      });
      card.addEventListener('mouseleave', () => {
        animate({
          targets: card,
          translateY: 0,
          boxShadow: '0 0 0 rgba(15,14,12,0)',
          duration: 250,
          easing: 'easeOutCubic'
        });
        animate({ targets: spotlight, opacity: 0, duration: 250, easing: 'easeOutCubic' });
      });
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        spotlight.style.background = `radial-gradient(circle 120px at ${x}px ${y}px, rgba(163,106,82,0.14), transparent)`;
      });
    });

    // Magnetic buttons
    document.querySelectorAll('.btn-magnetic').forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        animate({ targets: btn, translateX: x * 0.25, translateY: y * 0.25, duration: 200, easing: 'easeOutCubic' });
      });
      btn.addEventListener('mouseleave', () => {
        animate({ targets: btn, translateX: 0, translateY: 0, duration: 300, easing: 'easeOutElastic(1, .6)' });
      });
    });
  }

  // Pricing Widget Logic
  function initPricing() {
    const content = document.getElementById('pricing-content');
    const steps = document.querySelectorAll('.step-btn');
    if (!content || !steps.length) return;

    const pricingData = {
      creative: {
        title: "Creative",
        items: [
          { name: "Logo + basic brand", price: "RM 890" },
          { name: "Full visual identity", price: "RM 1,890" },
          { name: "Social + print pack", price: "from RM 1,450" }
        ],
        note: "Includes 2 rounds of revisions. Source files delivered."
      },
      print: {
        title: "Print Production",
        items: [
          { name: "Business cards (500)", price: "RM 380" },
          { name: "A3 posters (100)", price: "RM 620" },
          { name: "Full signage set", price: "quoted" }
        ],
        note: "High-quality local printing. Fast turnaround."
      },
      it: {
        title: "IT Support",
        items: [
          { name: "One-time repair", price: "RM 180–280" },
          { name: "Monthly basic", price: "RM 380/mo" },
          { name: "Monthly full", price: "RM 680/mo" }
        ],
        note: "On-site in JB area. Remote support included."
      },
      ai: {
        title: "AI & Automation",
        items: [
          { name: "Simple chatbot", price: "RM 1,250" },
          { name: "Workflow setup", price: "RM 980" },
          { name: "Custom image gen flow", price: "from RM 1,650" }
        ],
        note: "Built with tools you already use."
      },
      retainer: {
        title: "Monthly Retainers",
        items: [
          { name: "Starter (8h)", price: "RM 1,250/mo" },
          { name: "Growth (20h)", price: "RM 2,650/mo" },
          { name: "Full partnership", price: "RM 4,200/mo" }
        ],
        note: "Best value. Roll over unused hours. Priority response."
      }
    };

    const waNum = content.dataset.wa;
    const wa = (msg) => `https://wa.me/${waNum}?text=${encodeURIComponent(msg)}`;

    function render(step) {
      const data = pricingData[step];
      const card = document.createElement('div');
      card.className = 'card p-9 unified-card';
      card.innerHTML = `
        <div class="flex items-baseline justify-between mb-6">
          <h3 class="text-3xl font-semibold tracking-tight">${data.title}</h3>
          <a href="${wa('Hi Pancatz, I\'m interested in ' + data.title)}"
             class="text-sm underline hover:no-underline">Chat on WhatsApp →</a>
        </div>
        <div class="space-y-4 mb-8">
          ${data.items.map(i => `
            <div class="flex justify-between items-center border-b border-[var(--surface-border)] pb-4">
              <div>${i.name}</div>
              <div class="font-mono text-sm text-[var(--primary)]">${i.price}</div>
            </div>
          `).join('')}
        </div>
        <p class="text-sm text-[var(--muted-ink)]">${data.note}</p>
      `;
      content.innerHTML = '';
      content.appendChild(card);

      animate.set(card, { opacity: 0, translateY: 20 });
      animate({ targets: card, opacity: [0, 1], translateY: [20, 0], duration: 500, easing: 'easeOutExpo' });
    }

    steps.forEach(btn => {
      btn.addEventListener('click', () => {
        steps.forEach(b => {
          b.classList.remove('bg-[var(--ink)]', 'text-[var(--paper)]');
          b.classList.add('hover:bg-[var(--surface)]');
        });
        btn.classList.add('bg-[var(--ink)]', 'text-[var(--paper)]');
        btn.classList.remove('hover:bg-[var(--surface)]');
        render(btn.dataset.step);
      });
    });

    // Initialize first step
    steps[0].classList.add('bg-[var(--ink)]', 'text-[var(--paper)]');
    steps[0].classList.remove('hover:bg-[var(--surface)]');
    render('creative');
  }

  // Portfolio canvas tactility
  function initPortfolioCanvases() {
    const canvases = document.querySelectorAll('.portfolio-card canvas');
    canvases.forEach((canvas) => {
      const ctx = canvas.getContext('2d');
      const type = canvas.dataset.type;
      const rect = canvas.getBoundingClientRect();
      const cssW = rect.width;
      const cssH = rect.height;
      canvas.width = cssW * 2;
      canvas.height = cssH * 2;
      ctx.resetTransform();
      ctx.scale(2, 2);

      function draw() {
        ctx.clearRect(0, 0, cssW, cssH);
        ctx.strokeStyle = 'rgba(163, 106, 82, 0.25)';
        ctx.lineWidth = 1;

        if (type === 'creative') {
          for (let i = 0; i < 5; i++) {
            ctx.beginPath();
            ctx.moveTo(20 + i * 18, 30);
            ctx.quadraticCurveTo(80 + i * 6, 90, 60 + i * 12, 140);
            ctx.stroke();
          }
        } else {
          for (let x = 20; x < cssW; x += 22) {
            for (let y = 18; y < cssH; y += 22) {
              ctx.beginPath();
              ctx.arc(x, y, 1.5, 0, Math.PI * 2);
              ctx.stroke();
            }
          }
        }
      }
      draw();
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initTypingEffect();
    initHeroReveal();
    initScrollReveals();
    initCards();
    initPricing();
    initPortfolioCanvases();
  });
</script>
