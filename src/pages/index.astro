---
import Layout from '../layouts/Layout.astro';
import { site, faqs, whatsappIntents } from '../data/site';
import { Button, Card, Badge } from '@astryxdesign/core';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`;
const serviceGroups = [
  {
    title: 'Creative Hub',
    summary: 'Design and printed materials for campaigns, stores, launches, and everyday business needs.',
    chips: ['Graphic Design', 'Printing'],
  },
  {
    title: 'IT Services',
    summary: 'Hardware support, troubleshooting, setup, and practical AI workflows for small teams.',
    chips: ['IT Support', 'Hardware', 'AI Setup'],
  },
];
---

<Layout path="/" title={`${site.name} | Creative Hub + IT Services`}>
  <section class="section raw-grid rounded-3xl py-14 sm:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="kicker mb-3 inline-flex rounded-full border border-zinc-300 bg-white/80 px-3 py-1 text-zinc-700">CREATIVE HUB / IT SERVICES</p>
        <h1 class="hero-title font-extrabold text-zinc-900">Creative production and IT support, built for practical work.</h1>
        <p class="lead mt-5 max-w-2xl text-zinc-600">Design, print, hardware help, and AI workflow setup from one responsive team.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={waLink} label="Get Quote on WhatsApp" variant="primary" target="_blank" rel="noreferrer" />
          <Button href="/services" label="Explore Services" variant="secondary" />
        </div>
      </div>
      <Card padding={6} variant="default">
        <p class="kicker text-zinc-500">WORKFLOW / TRUST MODEL</p>
        <h2 class="mt-3 text-xl font-bold">How projects move with Pancatz</h2>
        <ol class="mt-4 space-y-3 text-sm text-zinc-700">
          <li><span class="font-semibold">01 Goal:</span> You share the outcome, constraint, and deadline.</li>
          <li><span class="font-semibold">02 Lane:</span> We route it into Creative Hub, IT Services, or a combined package.</li>
          <li><span class="font-semibold">03 Quote:</span> Timeline, scope, and budget are confirmed upfront.</li>
          <li><span class="font-semibold">04 Produce:</span> Design, print, repair, or workflow setup with clear updates.</li>
          <li><span class="font-semibold">05 Handover:</span> You receive final files, fixed devices, or practical next steps.</li>
        </ol>
      </Card>
    </div>
  </section>

  <section class="section py-8 sm:py-12">
    <div class="flex items-end justify-between gap-4">
      <h2 class="page-title font-bold tracking-tight text-zinc-900">Service Hubs</h2>
      <Button href="/services" label="View all →" variant="ghost" />
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {serviceGroups.map((group) => (
        <Card padding={6} variant="muted">
          <p class="kicker text-zinc-500">{group.title}</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">{group.summary}</p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.chips.map((chip) => (
              <li><Badge label={chip} variant="neutral" /></li>
            ))}
          </ul>
        </Card>
      ))}
    </div>
  </section>

  <section class="section py-10 sm:py-14">
    <Card padding={6} variant="default">
      <h2 class="page-title font-bold tracking-tight text-zinc-900">Frequently Asked Questions</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqs.map((faq) => (
          <article class="rounded-2xl border border-zinc-200 bg-white p-4">
            <h3 class="font-semibold text-zinc-900">{faq.q}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-600">{faq.a}</p>
          </article>
        ))}
      </div>
    </Card>
  </section>

  <section class="section pb-16">
    <div class="rounded-3xl bg-zinc-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Need a quick quote today?</h2>
      <p class="mt-2 max-w-2xl text-zinc-200">Share your project details on WhatsApp and we will suggest the right Creative Hub or IT Services package with timeline and cost estimate.</p>
      <Button href={waLink} label="WhatsApp Pancatz" variant="primary" target="_blank" rel="noreferrer" className="mt-6" />
    </div>
  </section>
</Layout>
