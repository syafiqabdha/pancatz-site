---
import Layout from '../layouts/Layout.astro';
import { site, whatsappIntents } from '../data/site';

const waGeneral = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`;
const waCreative = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.creativeHub)}`;
const waIT = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.repair)}`;
const waAI = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.itAi)}`;
---

<Layout>
  <!-- Hero -->
  <section class="section raw-grid pt-28 sm:pt-36 pb-24 sm:pb-32 relative overflow-hidden">
    <div class="max-w-5xl relative z-10">
      <h1 class="hero-title" id="hero-headline">
      </h1>
      <span id="hero-cursor" class="hero-cursor"></span>

      <p class="mt-7 max-w-md text-[1.05rem] text-[var(--muted-ink)] hero-reveal">
        One team for creative work and tech support. Premium design, print, and intelligent systems that keep your business moving.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row flex-wrap gap-4 hero-reveal">
        <a href="#what-you-need" class="btn-primary btn-magnetic">What do you need?</a>
        <a href="/pricing" class="btn-secondary btn-magnetic">See pricing</a>
      </div>

      <div class="mt-6 flex flex-wrap gap-2 text-xs text-[var(--muted-ink)] hero-reveal">
        <span class="px-3 py-1 rounded-full border border-[var(--surface-border)] bg-[var(--surface-solid)]">Johor Bahru & Kulai</span>
        <span class="px-3 py-1 rounded-full border border-[var(--surface-border)] bg-[var(--surface-solid)]">Remote Malaysia</span>
      </div>
    </div>

    <canvas id="hero-orb" class="hero-orb" width="560" height="560"></canvas>
  </section>

  <!-- Conversational starter -->
  <section id="what-you-need" class="section py-10 border-t border-[var(--surface-border)]">
    <div class="mb-6 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">START HERE</div>
      <h2 class="page-title">What do you need right now?</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 card-grid">
      <a href={waCreative} class="card p-6 flex flex-col unified-card">
        <div class="text-[var(--primary)] text-sm mb-1">CREATIVE</div>
        <div class="font-semibold text-xl">Design or Print</div>
        <div class="text-sm text-[var(--muted-ink)] mt-auto">Logo • Cards • Flyers • Brand</div>
      </a>
      <a href={waIT} class="card p-6 flex flex-col unified-card">
        <div class="text-[var(--primary)] text-sm mb-1">IT SUPPORT</div>
        <div class="font-semibold text-xl">Fix or Maintain</div>
        <div class="text-sm text-[var(--muted-ink)] mt-auto">Repairs • Retainers • Setup</div>
      </a>
      <a href={waAI} class="card p-6 flex flex-col unified-card">
        <div class="text-[var(--primary)] text-sm mb-1">AUTOMATION</div>
        <div class="font-semibold text-xl">AI & Workflows</div>
        <div class="text-sm text-[var(--muted-ink)] mt-auto">Chatbots • n8n • Image gen</div>
      </a>
      <a href="/pricing" class="card p-6 flex flex-col md:col-span-2 lg:col-span-1 unified-card">
        <div class="text-[var(--primary)] text-sm mb-1">PLANS</div>
        <div class="font-semibold text-xl">Monthly Retainers</div>
        <div class="text-sm text-[var(--muted-ink)] mt-auto">Predictable cost, always on</div>
      </a>
      <a href={waGeneral} class="card p-6 flex flex-col lg:col-span-1 unified-card">
        <div class="text-[var(--primary)] text-sm mb-1">OTHER</div>
        <div class="font-semibold text-xl">Just tell us</div>
        <div class="text-sm text-[var(--muted-ink)] mt-auto">We'll figure it out together</div>
      </a>
    </div>
  </section>

  <!-- Service Hubs -->
  <section id="services" class="section border-t border-[var(--surface-border)] py-16">
    <div class="mb-8 section-reveal">
      <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">WHAT WE DO</div>
      <h2 class="page-title">Two lanes.<br />One team.</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5 card-grid">
      <div class="card p-9 unified-card">
        <div class="uppercase text-xs tracking-[2px] text-[var(--primary)] mb-4">CREATIVE HUB</div>
        <h3 class="text-3xl font-semibold tracking-[-0.03em] mb-5">Design that prints.<br />Brands that last.</h3>

        <div class="text-[var(--muted-ink)] space-y-1.5 mb-10 text-[15px]">
          <div>Logo & brand systems</div>
          <div>Business cards, flyers, packaging</div>
          <div>Social kits & menus</div>
          <div>Banners, signage, print production</div>
        </div>

        <a href={waCreative} class="btn-secondary">Talk on WhatsApp</a>
      </div>

      <div class="card p-9 unified-card">
        <div class="uppercase text-xs tracking-[2px] text-[var(--primary)] mb-4">IT SERVICES</div>
        <h3 class="text-3xl font-semibold tracking-[-0.03em] mb-5">Systems that work.<br />Support that shows up.</h3>

        <div class="text-[var(--muted-ink)] space-y-1.5 mb-10 text-[15px]">
          <div>PC, laptop & hardware repair</div>
          <div>Network, WiFi & infrastructure</div>
          <div>Monthly Tech Care retainers</div>
          <div>AI automation & workflows</div>
        </div>

        <a href={waIT} class="btn-secondary">Talk on WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="section border-t border-[var(--surface-border)] py-16">
    <div class="mb-8 flex items-end justify-between section-reveal">
      <div>
        <div class="uppercase tracking-[2px] text-xs mb-2 text-[var(--primary)]">SELECT WORK</div>
        <h2 class="page-title">Work that holds up.</h2>
      </div>
      <a href="/portfolio" class="btn-secondary hidden sm:inline-block">See all</a>
    </div>

    <div class="grid md:grid-cols-2 gap-5 card-grid">
      <a href="/portfolio" class="card p-8 unified-card portfolio-card group">
        <canvas class="w-full h-48 mb-6 rounded-xl bg-[var(--surface-solid)]" data-type="creative"></canvas>
        <div class="font-semibold text-2xl tracking-[-0.02em]">Creative systems for local brands</div>
        <div class="text-sm text-[var(--muted-ink)] mt-1">Branding • Print • Packaging</div>
      </a>

      <a href="/portfolio" class="card p-8 unified-card portfolio-card group">
        <canvas class="w-full h-48 mb-6 rounded-xl bg-[var(--surface-solid)]" data-type="tech"></canvas>
        <div class="font-semibold text-2xl tracking-[-0.02em]">Reliable tech foundations</div>
        <div class="text-sm text-[var(--muted-ink)] mt-1">Infrastructure • Automation • Support</div>
      </a>
    </div>

    <a href="/portfolio" class="btn-secondary mt-6 inline-block sm:hidden">See all work</a>
  </section>

    <!-- Closer -->
  <section class="section py-16 sm:py-24 border-t border-[var(--surface-border)] text-center section-reveal">
    <div class="max-w-4xl mx-auto">
      <p class="text-[var(--ink)] cta-text font-semibold tracking-tight">Ready when you are.</p>
      <a href={waGeneral} class="btn-primary inline-block mt-6 sm:mt-8">Start a conversation</a>
    </div>
  </section>
</Layout>

<script>
  import { animate, onScroll, stagger } from 'animejs';

  // Reusable motion tokens
  const ease = 'easeOutExpo';
  const baseDuration = 800;

  // Typing effect on hero headline
  const headline = document.getElementById('hero-headline');
  const cursor = document.getElementById('hero-cursor');
  if (headline && cursor) {
    const sequences = [
      { text: 'Design and system', pause: 1000 },
      { text: 'Design that print', pause: 1000 },
      { text: 'System that run', pause: 1000 }
    ];

    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function typeText(text) {
      for (let i = 0; i <= text.length; i++) {
        headline.textContent = text.slice(0, i);
        await sleep(80);
      }
    }

    async function deleteText() {
      const text = headline.textContent;
      for (let i = text.length; i >= 0; i--) {
        headline.textContent = text.slice(0, i);
        await sleep(50);
      }
    }

    async function playSequence() {
      for (const seq of sequences) {
        await typeText(seq.text);
        await sleep(seq.pause);
        await deleteText();
        await sleep(300);
      }
      await typeText(sequences[sequences.length - 1].text);
    }

    playSequence();
  }

  // Hero reveal sequence for sub + buttons
  animate({
    targets: '.hero-reveal',
    opacity: [0, 1],
    translateY: [24, 0],
    duration: baseDuration,
    easing: ease,
    delay: stagger(120, { start: 200 })
  });

  // Section reveals on scroll
  animate.set('.section-reveal', { opacity: 0, translateY: 24 });
  document.querySelectorAll('.section-reveal').forEach(el => {
    onScroll({
      target: el,
      enter: 'top 85%',
      leave: 'bottom 10%',
      sync: false,
      debug: false,
    }).add({
      targets: el,
      opacity: [0, 1],
      translateY: [24, 0],
      duration: baseDuration,
      easing: ease
    });
  });

  // Card stagger reveals per section
  document.querySelectorAll('.card-grid').forEach(grid => {
    const cards = grid.querySelectorAll('.unified-card');
    animate.set(cards, { opacity: 0, translateY: 30, scale: 0.98 });
    onScroll({
      target: grid,
      enter: 'top 85%',
      leave: 'bottom 10%',
      sync: false,
    }).add({
      targets: cards,
      opacity: [0, 1],
      translateY: [30, 0],
      scale: [0.98, 1],
      duration: 900,
      easing: ease,
      delay: stagger(80)
    });
  });

  // Unified card hover effect (lift + spotlight)
  document.querySelectorAll('.unified-card').forEach(card => {
    const spotlight = document.createElement('span');
    spotlight.className = 'card-spotlight';
    card.appendChild(spotlight);

    card.addEventListener('mouseenter', () => {
      animate({
        targets: card,
        translateY: -6,
        boxShadow: ['0 0 0 rgba(15,14,12,0)', '8px 12px 0 rgba(15,14,12,0.12)'],
        duration: 250,
        easing: 'easeOutCubic'
      });
      animate({ targets: spotlight, opacity: [0, 1], duration: 250, easing: 'easeOutCubic' });
    });
    card.addEventListener('mouseleave', () => {
      animate({
        targets: card,
        translateY: 0,
        boxShadow: '0 0 0 rgba(15,14,12,0)',
        duration: 250,
        easing: 'easeOutCubic'
      });
      animate({ targets: spotlight, opacity: 0, duration: 250, easing: 'easeOutCubic' });
    });
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      spotlight.style.background = `radial-gradient(circle 120px at ${x}px ${y}px, rgba(163,106,82,0.14), transparent)`;
    });
  });

  // Magnetic buttons
  document.querySelectorAll('.btn-magnetic').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      animate({ targets: btn, translateX: x * 0.25, translateY: y * 0.25, duration: 200, easing: 'easeOutCubic' });
    });
    btn.addEventListener('mouseleave', () => {
      animate({ targets: btn, translateX: 0, translateY: 0, duration: 300, easing: 'easeOutElastic(1, .6)' });
    });
  });

  // Hero orb (scroll-synced pitch + hover glow)
  function initHeroOrb() {
    const canvas = document.getElementById('hero-orb');
    if (!canvas) return;

    const ctx = canvas.getContext('2d', { alpha: true });
    let rotation = 0;
    let targetRotation = 0;
    let isDragging = false;
    let lastY = 0;

    const clayColor = '#a36a52';
    const highlight = '#d4b39c';
    const shadow = '#6b4a3a';

    function drawOrb(pitch) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const cx = canvas.width / 2;
      const cy = canvas.height / 2;
      const radius = Math.min(canvas.width, canvas.height) * 0.42;

      const grad = ctx.createRadialGradient(
        cx - radius * 0.3, cy - radius * 0.35, radius * 0.15,
        cx + radius * 0.1, cy + radius * 0.2, radius * 1.1
      );
      grad.addColorStop(0, highlight);
      grad.addColorStop(0.35, clayColor);
      grad.addColorStop(1, shadow);

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate((pitch * 0.6) * Math.PI / 180);

      ctx.beginPath();
      ctx.arc(0, 0, radius, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      ctx.strokeStyle = 'rgba(255,255,255,0.15)';
      ctx.lineWidth = 1.2;
      for (let i = -3; i <= 3; i++) {
        const y = (i * radius * 0.28);
        ctx.beginPath();
        ctx.ellipse(0, y, radius * 0.95, radius * 0.22, 0, 0, Math.PI * 2);
        ctx.stroke();
      }

      ctx.beginPath();
      ctx.arc(-radius * 0.2, -radius * 0.25, radius * 0.65, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(255,255,255,0.35)';
      ctx.lineWidth = 18;
      ctx.stroke();

      ctx.restore();
    }

    // Magnetic orb (subtle cursor follow)
    let mouseX = 0, mouseY = 0, orbX = 0, orbY = 0;
    window.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      mouseX = (e.clientX - cx) * 0.08;
      mouseY = (e.clientY - cy) * 0.08;
    });

    function render() {
      orbX += (mouseX - orbX) * 0.08;
      orbY += (mouseY - orbY) * 0.08;
      canvas.style.marginLeft = `${orbX}px`;
      canvas.style.marginTop = `${orbY}px`;
      rotation += (targetRotation - rotation) * 0.08;
      drawOrb(rotation);
      requestAnimationFrame(render);
    }

    function updateFromScroll() {
      const scrollProgress = Math.min(window.scrollY / (document.body.scrollHeight * 0.25), 1);
      targetRotation = scrollProgress * 90;
    }

    window.addEventListener('scroll', () => updateFromScroll(), { passive: true });

    canvas.addEventListener('mousedown', (e) => { isDragging = true; lastY = e.clientY; });
    window.addEventListener('mouseup', () => isDragging = false);
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const delta = (e.clientY - lastY) * 0.8;
      targetRotation += delta;
      lastY = e.clientY;
    });

    canvas.addEventListener('touchstart', (e) => { isDragging = true; lastY = e.touches[0].clientY; });
    window.addEventListener('touchend', () => isDragging = false);
    window.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const delta = (e.touches[0].clientY - lastY) * 0.8;
      targetRotation += delta;
      lastY = e.touches[0].clientY;
    });

    // Reveal orb
    animate({
      targets: canvas,
      opacity: [0, 0.9],
      scale: [0.9, 1],
      duration: 1200,
      easing: ease,
      delay: 400
    });

    updateFromScroll();
    render();
  }

  // Portfolio canvas tactility
  function initPortfolioCanvases() {
    const canvases = document.querySelectorAll('.portfolio-card canvas');
    canvases.forEach((canvas) => {
      const ctx = canvas.getContext('2d');
      const type = canvas.dataset.type;
      const rect = canvas.getBoundingClientRect();
      const cssW = rect.width;
      const cssH = rect.height;
      canvas.width = cssW * 2;
      canvas.height = cssH * 2;
      ctx.resetTransform();
      ctx.scale(2, 2);

      function draw() {
        ctx.clearRect(0, 0, cssW, cssH);
        ctx.strokeStyle = 'rgba(163, 106, 82, 0.25)';
        ctx.lineWidth = 1;

        if (type === 'creative') {
          for (let i = 0; i < 5; i++) {
            ctx.beginPath();
            ctx.moveTo(20 + i * 18, 30);
            ctx.quadraticCurveTo(80 + i * 6, 90, 60 + i * 12, 140);
            ctx.stroke();
          }
        } else {
          for (let x = 20; x < cssW; x += 22) {
            for (let y = 18; y < cssH; y += 22) {
              ctx.beginPath();
              ctx.arc(x, y, 1.5, 0, Math.PI * 2);
              ctx.stroke();
            }
          }
        }
      }
      draw();
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initHeroOrb();
    initPortfolioCanvases();
  });
</script>
