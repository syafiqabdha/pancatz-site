---
import Layout from '../layouts/Layout.astro';
import { site, services, portfolioItems, faqs, whatsappIntents } from '../data/site';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`;
---

<Layout path="/" title={`${site.name} | Design, Print, Photography, IT & AI`}>
  <section class="section raw-grid rounded-3xl py-14 sm:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="kicker mb-3 inline-flex rounded-full border border-zinc-300 bg-white/80 px-3 py-1 text-zinc-700">Kelapa Sawit • Kulai • Johor</p>
        <h1 class="hero-title font-extrabold text-zinc-900">Crafted utility for local businesses, families, and teams.</h1>
        <p class="lead mt-5 max-w-2xl text-zinc-600">From printed marketing materials and visual content to PC repair and practical AI workflow support, Pancatz delivers clear outcomes with friendly local service.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink} class="btn-primary interactive-lift focus-ring" target="_blank" rel="noreferrer">Get Quote on WhatsApp</a>
          <a href="/services" class="btn-secondary interactive-lift focus-ring">Explore Services</a>
        </div>
      </div>
      <div class="studio-card p-6 text-zinc-800">
        <p class="kicker text-zinc-500">WORKFLOW / TRUST MODEL</p>
        <h2 class="mt-3 text-xl font-bold">How projects move with Pancatz</h2>
        <ol class="mt-4 space-y-3 text-sm text-zinc-700">
          <li><span class="font-semibold">01 Goal:</span> You share objective, constraints, and deadline.</li>
          <li><span class="font-semibold">02 Scope:</span> We propose the leanest service mix for your case.</li>
          <li><span class="font-semibold">03 Quote:</span> Timeline and budget are confirmed upfront.</li>
          <li><span class="font-semibold">04 Produce:</span> Design/print/photo/tech execution with clear updates.</li>
          <li><span class="font-semibold">05 Deliver:</span> Handover with practical next steps and support.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section py-8 sm:py-12">
    <div class="flex items-end justify-between gap-4">
      <h2 class="page-title font-bold tracking-tight text-zinc-900">Core Services</h2>
      <a href="/services" class="focus-ring rounded text-sm font-semibold text-[var(--link)] hover:underline">View all →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.slice(0, 3).map((service) => (
        <article class="studio-card interactive-lift p-5">
          <p class="kicker text-zinc-500">{service.eyebrow}</p>
          <h3 class="mt-2 text-lg font-semibold text-zinc-900">{service.title}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-600">{service.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section py-10 sm:py-14">
    <div class="flex items-end justify-between gap-4">
      <h2 class="page-title font-bold tracking-tight text-zinc-900">Recent Work Highlights</h2>
      <a href="/portfolio" class="focus-ring rounded text-sm font-semibold text-[var(--link)] hover:underline">See gallery →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {portfolioItems.slice(0, 3).map((item) => (
        <article class="studio-card interactive-lift overflow-hidden">
          <div class="overflow-hidden">
            <img src={item.image} alt={item.title} class="h-48 w-full object-cover" loading="lazy" />
          </div>
          <div class="p-4">
            <p class="kicker text-zinc-500">{item.category}</p>
            <h3 class="mt-1 text-lg font-semibold text-zinc-900">{item.title}</h3>
            <p class="mt-2 text-sm text-zinc-600">{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section py-10 sm:py-14">
    <div class="studio-card p-6 sm:p-8">
      <h2 class="page-title font-bold tracking-tight text-zinc-900">Frequently Asked Questions</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqs.map((faq) => (
          <article class="rounded-2xl border border-zinc-200 bg-white p-4">
            <h3 class="font-semibold text-zinc-900">{faq.q}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-600">{faq.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section pb-16">
    <div class="rounded-3xl bg-zinc-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Need a quick quote today?</h2>
      <p class="mt-2 max-w-2xl text-zinc-200">Share your project details on WhatsApp and we will suggest the best package with timeline and cost estimate.</p>
      <a href={waLink} class="btn-primary interactive-lift focus-ring mt-6" target="_blank" rel="noreferrer">WhatsApp Pancatz</a>
    </div>
  </section>
</Layout>
