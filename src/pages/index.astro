---
import Layout from '../layouts/Layout.astro';
import { site, services, portfolioItems, faqs } from '../data/site';

const waLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Layout path="/" title={`${site.name} | Design, Print, Photography, IT & AI`}>
  <section class="section py-14 sm:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="mb-3 inline-flex rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-zinc-600">Kelapa Sawit • Kulai • Johor</p>
        <h1 class="text-4xl font-extrabold tracking-tight text-zinc-900 sm:text-5xl">Creative + Technical Services That Help Local Businesses Move Faster</h1>
        <p class="mt-5 text-base leading-7 text-zinc-600 sm:text-lg">From printed marketing materials and visual content to PC repair and practical AI workflow support, Pancatz delivers clear outcomes with friendly local service.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={waLink} class="btn-primary" target="_blank" rel="noreferrer">Get Quote on WhatsApp</a>
          <a href="/services" class="btn-secondary">Explore Services</a>
        </div>
      </div>
      <div class="card bg-gradient-to-br from-zinc-900 to-zinc-700 text-white">
        <h2 class="text-xl font-bold">Why clients choose Pancatz</h2>
        <ul class="mt-4 space-y-3 text-sm text-zinc-100">
          <li>• One partner for design, print, photography, and IT support</li>
          <li>• Fast response through WhatsApp for quote and scheduling</li>
          <li>• Solutions designed for local SMEs, schools, and families</li>
          <li>• Practical and budget-aware packages, no unnecessary upselling</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section py-8 sm:py-12">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Core Services</h2>
      <a href="/services" class="text-sm font-semibold text-[var(--link)] hover:underline">View all →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.slice(0, 3).map((service) => (
        <article class="card">
          <h3 class="text-lg font-semibold text-zinc-900">{service.title}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-600">{service.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section py-10 sm:py-14">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Recent Work Highlights</h2>
      <a href="/portfolio" class="text-sm font-semibold text-[var(--link)] hover:underline">See gallery →</a>
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {portfolioItems.slice(0, 3).map((item) => (
        <article class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
          <img src={item.image} alt={item.title} class="h-48 w-full object-cover" loading="lazy" />
          <div class="p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">{item.category}</p>
            <h3 class="mt-1 text-lg font-semibold text-zinc-900">{item.title}</h3>
            <p class="mt-2 text-sm text-zinc-600">{item.summary}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section py-10 sm:py-14">
    <div class="rounded-3xl border border-zinc-200 bg-white p-6 sm:p-8">
      <h2 class="text-2xl font-bold tracking-tight text-zinc-900">Frequently Asked Questions</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqs.map((faq) => (
          <article class="rounded-2xl border border-zinc-200 p-4">
            <h3 class="font-semibold text-zinc-900">{faq.q}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-600">{faq.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section pb-16">
    <div class="rounded-3xl bg-zinc-900 p-8 text-white">
      <h2 class="text-2xl font-bold">Need a quick quote today?</h2>
      <p class="mt-2 max-w-2xl text-zinc-200">Share your project details on WhatsApp and we will suggest the best package with timeline and cost estimate.</p>
      <a href={waLink} class="btn-primary mt-6" target="_blank" rel="noreferrer">WhatsApp Pancatz</a>
    </div>
  </section>
</Layout>
