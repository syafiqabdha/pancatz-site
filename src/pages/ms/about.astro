---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';
import { Card } from '@astryxdesign/core';

const msTitle = 'Tentang Kami | Pancatz | Johor Bahru, Malaysia';
const msDesc = 'Pancatz ialah jenama servis praktikal untuk reka grafik, percetakan, baiki komputer, dan sokongan AI di Johor Bahru, Malaysia.';
---

<Layout path="/ms/about" title={msTitle} description={msDesc}>
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">Tentang Pancatz</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">Pancatz ialah jenama servis praktikal untuk individu dan pasukan kecil yang mahukan hasil kerja kreatif dan sokongan teknikal yang boleh diharap dari satu talian komunikasi.</p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      <Card padding={5}>
        <h2 class="text-xl font-bold text-zinc-900">Misi kami</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-600">Membantu perniagaan dan individu tampil profesional, memastikan peranti berfungsi dengan baik, dan mengamalkan workflow digital tanpa kerumitan yang tidak perlu.</p>
      </Card>
      <Card padding={5}>
        <h2 class="text-xl font-bold text-zinc-900">Cara kami bekerja</h2>
        <p class="mt-3 text-sm leading-6 text-zinc-600">Kami bermula dengan matlamat anda, cadangkan laluan paling mudah, dan komunikasi sentiasa jelas melalui WhatsApp dari sebut harga hingga serahan akhir.</p>
      </Card>
      <Card padding={5} className="md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Dua laluan servis</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <Card padding={4} variant="muted">
            <p class="kicker text-zinc-500">Creative Hub</p>
            <p class="mt-2 text-sm leading-6 text-zinc-600">Sistem reka, aset media sosial, flyer, menu, label, kad perniagaan, dan bahan siap cetak.</p>
          </Card>
          <Card padding={4} variant="muted">
            <p class="kicker text-zinc-500">Perkhidmatan IT</p>
            <p class="mt-2 text-sm leading-6 text-zinc-600">Baiki komputer, selenggara, persediaan perisian, semakan sandaran, alat AI, dan automasi workflow ringan.</p>
          </Card>
        </div>
      </Card>
      <Card padding={5} className="md:col-span-2">
        <h2 class="text-xl font-bold text-zinc-900">Model operasi</h2>
        <ol class="mt-4 grid gap-3 text-sm text-zinc-700 sm:grid-cols-5">
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">01</span><p class="mt-1 font-semibold">Matlamat</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">02</span><p class="mt-1 font-semibold">Skop</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">03</span><p class="mt-1 font-semibold">Sebut Harga</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">04</span><p class="mt-1 font-semibold">Hasil</p></li>
          <li class="rounded-xl border border-zinc-200 bg-white p-3"><span class="kicker text-zinc-500">05</span><p class="mt-1 font-semibold">Serahan</p></li>
        </ol>
      </Card>
    </div>
  </section>
</Layout>
