---
import Layout from '../../layouts/Layout.astro';
import { site, services, whatsappIntents } from '../../data/site';
import { Button, Card } from '@astryxdesign/core';

const intentBySlug = {
  'creative-hub-design': whatsappIntents.creativeHub,
  'creative-hub-print': whatsappIntents.printing,
  'it-services-repair': whatsappIntents.repair,
  'it-services-ai': whatsappIntents.itAi,
};

const msTitle = 'Servis | Pancatz | Reka Grafik, Percetakan, IT & AI | Johor Bahru';
const msDesc = 'Creative Hub untuk reka grafik dan percetakan. Perkhidmatan IT untuk baiki komputer, rangkaian, dan persediaan AI. Berpangkalan di Johor Bahru.';
---

<Layout path="/ms/services" title={msTitle} description={msDesc}>
  <section class="section py-14 sm:py-20">
    <h1 class="page-title font-extrabold text-zinc-900">Servis</h1>
    <p class="lead mt-4 max-w-3xl text-zinc-600">Pancatz kini diatur sekitar dua laluan utama: Creative Hub untuk reka dan cetak, dan Perkhidmatan IT untuk baiki, selenggara, AI, dan sokongan workflow digital.</p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {services.map((service) => {
        const serviceWaLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(intentBySlug[service.slug])}`;
        return (
          <Card padding={5} variant="default" id={service.slug}>
            <p class="kicker text-zinc-500">{service.eyebrow}</p>
            <h2 class="mt-2 text-xl font-bold text-zinc-900">{service.title}</h2>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">{service.group}</p>
            <p class="mt-3 text-sm leading-6 text-zinc-600">{service.description}</p>

            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Sesuai untuk</h3>
                <ul class="mt-2 space-y-1 text-sm text-zinc-700">
                  {service.bestFor.map((item) => (
                    <li>• {item}</li>
                  ))}
                </ul>
              </div>
              <div>
                <h3 class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Maklumat diperlukan</h3>
                <ul class="mt-2 space-y-1 text-sm text-zinc-700">
                  {service.quoteNeeds.map((item) => (
                    <li>• {item}</li>
                  ))}
                </ul>
              </div>
            </div>

            <ul class="mt-4 space-y-2 text-sm text-zinc-700">
              {service.bullets.map((bullet) => (
                <li>• {bullet}</li>
              ))}
            </ul>

            <Button href={serviceWaLink} label={`Tanya tentang ${service.group}`} variant="secondary" className="mt-5" target="_blank" rel="noreferrer" />
          </Card>
        );
      })}
    </div>
  </section>

  <section class="section pb-16">
    <Card padding={6} variant="default">
      <h2 class="text-2xl font-bold text-zinc-900">Minta pakej khas</h2>
      <p class="mt-2 text-zinc-600">Beritahu kami bajet, tarikh sasaran, dan matlamat anda. Kami boleh gabungkan reka, cetak, baiki, dan AI dalam satu pelan yang praktikal.</p>
      <Button href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(whatsappIntents.general)}`} label="WhatsApp Kami" variant="primary" className="mt-6" target="_blank" rel="noreferrer" />
    </Card>
  </section>
</Layout>
